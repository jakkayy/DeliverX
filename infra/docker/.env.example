# ============================================================
# Environment Variables — copy this file to .env
# ============================================================

# PostgreSQL
POSTGRES_DB=grab_db
POSTGRES_USER=grab_user
POSTGRES_PASSWORD=grab_secret_password

# Redis
REDIS_PASSWORD=redis_secret_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Service Ports
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
USER_SERVICE_PORT=8082
ORDER_SERVICE_PORT=8083
TRACKING_SERVICE_PORT=8084
PAYMENT_SERVICE_PORT=8085
NOTIFICATION_SERVICE_PORT=8086

# Google Maps (for geocoding & routing)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT_PATH=/app/config/firebase-service-account.json

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
